# Set to 1 on Sally to mock sign-in/checkout in dev (no Supabase/Stripe required).
# Set to 0 to require real Supabase/Stripe wiring on localhost.
NEXT_PUBLIC_LOCAL_ROUTE_PREVIEW=1

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-vercel-server-side-secret
CRON_SECRET=replace-with-random-cron-secret
STRIPE_SECRET_KEY=sk_test_replace-with-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_replace-with-webhook-secret
STRIPE_MONTHLY_PRICE_ID=price_replace-with-monthly-foundry-dues
STRIPE_YEARLY_PRICE_ID=price_replace-with-yearly-foundry-dues

# Harvey private cockpit. Never place real values in this tracked example.
# Production always fails closed if either server-only value is missing.
HARVEY_PRIVATE_ACCESS_ENFORCED=0
HARVEY_PRIVATE_PASSWORD_VERIFIER=
HARVEY_PRIVATE_SESSION_SECRET=
