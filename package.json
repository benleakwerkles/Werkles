    "gd:thread-refresh": "node foreman/gd-intent-router/gd-intent-router.mjs thread-refresh",
    "gd:gimpdash": "node -e \"require('child_process').execSync('start http://127.0.0.1:4317/#gimpdash',{stdio:'inherit',shell:true})\"",
