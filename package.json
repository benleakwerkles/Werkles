    "shakespeare:raw": "node scripts/foreman/shakespeare-v0.mjs raw",
    "shakespeare:self-test": "node scripts/foreman/shakespeare-v0.mjs self-test",
    "AUTONOMOUS_ROUND_TRIP_TEST": "node scripts/foreman/autonomous-round-trip-test.mjs --execute",
