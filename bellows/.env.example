# Bellows local configuration (copy to .env — never commit .env)

# dry-run | local | supabase
BELLOWS_MODE=dry-run

# Local storage root for ingested assets
BELLOWS_STORAGE_DIR=./data/assets

# Local job queue file (JSON lines)
BELLOWS_QUEUE_PATH=./data/queue.jsonl

# Ghost Forge base URL (stub only until deploy gate cleared)
GHOST_FORGE_URL=

# Supabase (stub only until schema/credentials gate cleared)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
