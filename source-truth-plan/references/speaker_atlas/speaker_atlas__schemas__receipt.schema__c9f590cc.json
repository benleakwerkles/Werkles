{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Speaker Receipt Schema V0",
  "type": "object",
  "required": [
    "receipt_id",
    "packet_id",
    "status",
    "evidence"
  ],
  "additionalProperties": true,
  "properties": {
    "receipt_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "packet_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "mission": {
      "type": "string",
      "minLength": 1
    },
    "producer": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "ACK",
        "ARTIFACT",
        "BLOCKER",
        "RECEIPT_PROVEN",
        "PASS",
        "FAIL"
      ]
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "object",
      "minProperties": 1
    }
  }
}
