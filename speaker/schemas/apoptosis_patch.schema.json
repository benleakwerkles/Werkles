{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://werkles.local/speaker/schemas/apoptosis_patch.schema.json",
  "title": "Speaker Apoptosis Patch V0",
  "type": "object",
  "required": [
    "patch_id",
    "reviewer",
    "decisions"
  ],
  "additionalProperties": true,
  "properties": {
    "patch_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "reviewer": {
      "type": "object",
      "required": [
        "aeye",
        "model_family"
      ],
      "additionalProperties": true,
      "properties": {
        "aeye": {
          "type": "string",
          "enum": ["Ender"]
        },
        "model_family": {
          "type": "string",
          "enum": ["Claude"]
        }
      }
    },
    "decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "doctrine_id",
          "outcome",
          "reason"
        ],
        "additionalProperties": true,
        "properties": {
          "doctrine_id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9_.:-]+$"
          },
          "outcome": {
            "type": "string",
            "enum": ["GRAVEYARD", "DEPRECATE", "DEPRECATED", "KEEP"]
          },
          "reason": {
            "type": "string"
          }
        }
      }
    }
  }
}
