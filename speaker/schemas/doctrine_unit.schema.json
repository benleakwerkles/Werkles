{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://werkles.local/speaker/schemas/doctrine_unit.schema.json",
  "title": "Speaker Doctrine Unit Frontmatter V0",
  "type": "object",
  "required": [
    "doctrine_id",
    "title",
    "status",
    "source_receipt_id",
    "created_at",
    "owner"
  ],
  "additionalProperties": true,
  "properties": {
    "doctrine_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["DRAFT", "ACTIVE", "SUPERSEDED", "QUARANTINED", "GRAVEYARD", "DEPRECATED"]
    },
    "source_receipt_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "supersedes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "evidence": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "receipt_path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    }
  }
}
