+function relayTaskAgeMs(session) {
+  const t = Date.parse(session?.updatedAt || session?.startedAt || 0);
+  if (!t || Number.isNaN(t)) return null;
+  return Date.now() - t;
+}
+
+function relayTaskIsStale(session) {
+  const state = session?.state || "idle";
+  if (!["preparing", "delivering"].includes(state)) return false;
+  const ageMs = relayTaskAgeMs(session);
+  return ageMs == null || ageMs >= RELAY_TASK_STALE_MS;
+}
+
+function relayLockIsStale(relayLock) {
+  if (!relayLock || relayLock.status !== "RUNNING") return false;
+  const t = Date.parse(relayLock.startedAt || relayLock.updatedAt || 0);
+  if (!t || Number.isNaN(t)) return true;
+  return Date.now() - t >= RELAY_TASK_STALE_MS;
+}
